import textwrap

def wrap(string, max_width):
    n=0
    a=""
    for s in range(len(string)):
        if n!=max_width:
            a=a+string[s]
            n=n+1
        elif n==max_width:
            a=a+"\n"+string[s]
            n=1      
    return a

if __name__ == '__main__':
    string, max_width = input(), int(input())
    result = wrap(string, max_width)
    print(result)